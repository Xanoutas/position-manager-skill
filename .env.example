# Required
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
WALLET_ADDRESS=YOUR_SOLANA_WALLET_PUBLIC_KEY

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK

# Alert interval in minutes (default: 15)
ALERT_INTERVAL_MINUTES=15

# SQLite database path (default: ~/.position-manager/pnl.db)
# PNL_DB_PATH=/custom/path/pnl.db

# CoinGecko API key for prices (optional, uses public API if not set)
# COINGECKO_API_KEY=YOUR_KEY
